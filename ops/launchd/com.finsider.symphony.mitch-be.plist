  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>30</integer>

  <key>StandardOutPath</key>
  <string>/Users/dm3n/Projects/symphony/logs/launchd.mitch-be.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/dm3n/Projects/symphony/logs/launchd.mitch-be.err.log</string>
</dict>
</plist>
